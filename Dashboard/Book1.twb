      <column caption='High Risk%' datatype='real' default-format='p0.0%' name='[Calculation_572801588653465602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [risk_level] = &quot;High Risk&quot; THEN [grid_id] END) / COUNT([grid_id])' />
